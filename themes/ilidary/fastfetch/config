{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "linux",
    "color": {
      "1": "green",
      "2": "green"
    },
    "padding": {
      "right": 2
    }
  },
  "display": {
    "separator": "  →  ",
    "color": {
      "keys": "green",
      "title": "bright_green"
    }
  },
  "modules": [
    {
      "type": "title",
      "format": "{user-name}@{host-name}"
    },
    "separator",
    {
      "type": "os",
      "key": "OS     "
    },
    {
      "type": "kernel",
      "key": "Kernel "
    },
    {
      "type": "uptime",
      "key": "Uptime "
    },
    {
      "type": "packages",
      "key": "Pkgs   "
    },
    {
      "type": "shell",
      "key": "Shell  "
    },
    {
      "type": "wm",
      "key": "WM     "
    },
    {
      "type": "terminal",
      "key": "Term   "
    },
    "separator",
    {
      "type": "cpu",
      "key": "CPU    ",
      "showPeCoreCount": true
    },
    {
      "type": "gpu",
      "key": "GPU    "
    },
    {
      "type": "memory",
      "key": "RAM    "
    },
    {
      "type": "disk",
      "key": "Disk   ",
      "folders": "/"
    },
    "break",
    {
      "type": "colors",
      "paddingLeft": 2,
      "symbol": "circle"
    }
  ]
}
