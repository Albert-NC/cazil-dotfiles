{
    "layer": "top",
    "position": "top",
    "height": 30,
    "width": 0,
    "spacing": 3,
    "exclusive": false,
    "modules-left": [
        "hyprland/workspaces#pacman"
    ],
    "modules-center": [
        "clock",
        "mpris"
    ],
    "modules-right": [
        "battery#cazil_elegant",
        "network",
        "bluetooth",
        "tray"
    ],
    "hyprland/workspaces#pacman": {
        "format": " {icon} ",
        "all-outputs": true,
        "active-only": false,
        "on-click": "activate",
        "format-icons": {
            "active": "ґ░Кп",
            "default": "ґ░Ка",
            "empty": "яДС"
        },
        "persistent-workspaces": {}
    },
    "clock": {
        "format": "ЁЯХС {:%H:%M} | ЁЯУЕ {:%d/%m}",
        "tooltip-format": "<big>{:%Y-%m-%d}</big>\n{calendar}"
    },
    "network": {
        "format-wifi": "яЗл Identity Protected",
        "format-ethernet": "ЁЯФЧ Identity Protected",
        "format-disconnected": "тЪая╕П Not Connect",
        "on-click": "bash $HOME/.local/bin/toggle-radio wifi on",
        "on-click-right": "bash $HOME/.local/bin/toggle-radio wifi off",
        "tooltip-format": "ЁЯФТ Network Masked\nTraffic via Secure Tunnel",
        "tooltip-format-wifi": "яЗл {essid} ({signaldBm}dBm)\nIP: Hidden",
        "tooltip-format-ethernet": "ЁЯФЧ {ifname}\nIP: Hidden",
        "tooltip-format-disconnected": "Desconectado"
    },
    "mpris": {
        "format": "{player_icon} {artist} - {title}",
        "format-paused": "{status_icon} <i>{artist} - {title}</i>",
        "player-icons": {
            "default": "тЦ╢",
            "mpv": "ЁЯО╡",
            "vlc": "ґ░Х╝",
            "spotify": "яЖ╝"
        },
        "status-icons": {
            "paused": "тП╕"
        },
        "max-length": 40
    },
    "bluetooth": {
        "format": "яКУ {num_devices}",
        "format-disabled": "яКУ Off",
        "format-connected": "яКУ {num_devices}",
        "on-click": "bash $HOME/.local/bin/toggle-radio bt on",
        "on-click-right": "bash $HOME/.local/bin/toggle-radio bt off",
        "interval": 5
    },
    "pulseaudio": {
        "format": "тЩк {volume}%",
        "format-muted": "ЁЯФЗ Muted"
    },
    "pulseaudio#microphone": {
        "format": "ЁЯОд {volume}%",
        "format-source-muted": "ЁЯФЗ Muted"
    },
    "battery#cazil_elegant": {
        "states": {
            "warning": 25,
            "critical": 10
        },
        "format": "{icon} {capacity}% ({time})",
        "format-charging": "тЪб {capacity}%",
        "format-full": "Full: {icon}",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    }
}